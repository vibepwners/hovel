common --announce_rc

build --color=yes
build --curses=yes
build --action_env=PYTHONDONTWRITEBYTECODE=1
build --incompatible_default_to_explicit_init_py

test --test_output=errors
test --test_env=PYTHONDONTWRITEBYTECODE=1

build:buildbuddy --bes_backend=grpcs://remote.buildbuddy.io
build:buildbuddy --bes_results_url=https://app.buildbuddy.io/invocation/
build:buildbuddy --remote_cache=grpcs://remote.buildbuddy.io
build:buildbuddy --remote_cache_compression=true
build:buildbuddy --remote_upload_local_results=false

build:local-cache --disk_cache=/var/tmp/bazel-cache/hovel
build:local-cache --remote_upload_local_results=true

# NativeLink remote execution uses the remote CAS as the cache. Do NOT add
# --disk_cache (i.e. --config=local-cache) here: combined with --remote_executor,
# Bazel satisfies input blobs from the local disk cache without uploading them to
# the remote CAS, so the worker fails with "Object not found in either fast or
# slow store" (e.g. the hermetic Python interpreter). Remote cache only.
build:nativelink --remote_cache=grpc://nativelink:50051
build:nativelink --remote_executor=grpc://nativelink:50051
build:nativelink --remote_upload_local_results=true

build:nativelink-minimal --config=nativelink
build:nativelink-minimal --remote_download_minimal

build:local --config=local-cache

build:ci --config=buildbuddy
build:ci --build_metadata=ROLE=CI
build:ci --noslim_profile
build:ci --experimental_profile_include_target_label
build:ci --experimental_profile_include_primary_output
build:ci --remote_upload_local_results=true

# picblobs module configuration. The imported modules/picblobs/.bazelrc is
# retained only as historical source context; active config lives here.
build:picblobs_base --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
build:picblobs_base --sandbox_default_allow_network=false
build:picblobs_base --nolegacy_external_runfiles

# Register the cross-toolchain matrix only for targets that compile C/C++.
# Pure repository quality targets use picblobs_base so they neither fetch
# unrelated compiler archives nor invalidate Bazel's analysis cache.
build:picblobs_cross --config=picblobs_base
build:picblobs_cross --extra_toolchains=//modules/picblobs/toolchains:all

# Platform configs intentionally do not expand Picblobs defaults. Combine them
# with --config=picblobs_cross or --config=picblobs_ci so the cross toolchains
# and base settings are applied exactly once.
build:linux_x86_64          --platforms=//modules/picblobs/platforms:linux_x86_64
build:linux_i686            --platforms=//modules/picblobs/platforms:linux_i686
build:linux_aarch64         --platforms=//modules/picblobs/platforms:linux_aarch64
build:linux_armv5_arm       --platforms=//modules/picblobs/platforms:linux_armv5_arm
build:linux_armv5_thumb     --platforms=//modules/picblobs/platforms:linux_armv5_thumb
build:linux_armv7_thumb     --platforms=//modules/picblobs/platforms:linux_armv7_thumb
build:linux_s390x           --platforms=//modules/picblobs/platforms:linux_s390x
build:linux_mipsel32        --platforms=//modules/picblobs/platforms:linux_mipsel32
build:linux_mipsbe32        --platforms=//modules/picblobs/platforms:linux_mipsbe32
build:linux_sparcv8         --platforms=//modules/picblobs/platforms:linux_sparcv8
build:linux_powerpc         --platforms=//modules/picblobs/platforms:linux_powerpc
build:linux_ppc64le         --platforms=//modules/picblobs/platforms:linux_ppc64le
build:linux_riscv64         --platforms=//modules/picblobs/platforms:linux_riscv64

build:freebsd_x86_64        --platforms=//modules/picblobs/platforms:freebsd_x86_64
build:freebsd_i686          --platforms=//modules/picblobs/platforms:freebsd_i686
build:freebsd_aarch64       --platforms=//modules/picblobs/platforms:freebsd_aarch64
build:freebsd_armv5_arm     --platforms=//modules/picblobs/platforms:freebsd_armv5_arm
build:freebsd_armv5_thumb   --platforms=//modules/picblobs/platforms:freebsd_armv5_thumb
build:freebsd_armv7_thumb   --platforms=//modules/picblobs/platforms:freebsd_armv7_thumb
build:freebsd_mipsel32      --platforms=//modules/picblobs/platforms:freebsd_mipsel32
build:freebsd_mipsbe32      --platforms=//modules/picblobs/platforms:freebsd_mipsbe32

build:windows_x86_64        --platforms=//modules/picblobs/platforms:windows_x86_64
build:windows_i686          --platforms=//modules/picblobs/platforms:windows_i686
build:windows_aarch64       --platforms=//modules/picblobs/platforms:windows_aarch64

build:picblobs_debug --copt=-g --copt=-DPIC_LOG_ENABLE
build:picblobs_debug --strip=never
build:picblobs_release --strip=always

build:picblobs_lint --config=picblobs_cross
build:picblobs_lint --aspects=//modules/picblobs/bazel:lint.bzl%clang_tidy_aspect
build:picblobs_lint --output_groups=lint_results

build:picblobs_ci --config=picblobs_lint
build:picblobs_ci --action_env=PICBLOBS_REQUIRE_LINT_TOOLS=1
test:picblobs_ci --test_env=PICBLOBS_REQUIRE_LINT_TOOLS=1
test:picblobs_ci --test_output=all
test:picblobs_ci --test_verbose_timeout_warnings

build:picblobs_quality --config=picblobs_base
build:picblobs_quality --action_env=PICBLOBS_REQUIRE_LINT_TOOLS=1
test:picblobs_quality --test_env=PICBLOBS_REQUIRE_LINT_TOOLS=1
test:picblobs_quality --test_output=all

try-import %workspace%/.bazelrc.user
