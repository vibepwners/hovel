    target_compatible_with = ["@platforms//os:windows"],
    deps = [
        "//modules/squatter/windows/src:framing",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)

cc_test(
    name = "cmd_integration_test.exe",
    srcs = [
        "cmd_integration_test.cc",
        "mux_peer.h",
    ],
