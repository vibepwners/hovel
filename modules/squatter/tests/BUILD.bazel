load("@rules_cc//cc:defs.bzl", "cc_test")

# gazelle:ignore

# Tests are Windows .exe (MinGW gcc appends .exe to the link output, so Bazel
# must expect it) and run under Wine via //tools/wine:wine_run.

_WINDOWS_TEST_LINKOPTS = [
    "-lws2_32",
    "-lshlwapi",
]

cc_test(
    name = "gtest_smoke.exe",
    srcs = ["gtest_smoke.cc"],
    linkopts = _WINDOWS_TEST_LINKOPTS,
    target_compatible_with = ["@platforms//os:windows"],
    deps = [
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)

cc_test(
    name = "frame_test.exe",
    srcs = ["frame_test.cc"],
    linkopts = _WINDOWS_TEST_LINKOPTS,
    target_compatible_with = ["@platforms//os:windows"],
    deps = [
        "//modules/squatter/windows/src:frame",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)

cc_test(
    name = "framing_test.exe",
