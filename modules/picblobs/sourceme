#!/usr/bin/env bash
# Source this file to run the Task-backed setup path:
#   source sourceme
#
# All setup logic lives in one place: `task setup` (see Taskfile.yml).

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  echo "error: this script must be sourced, not executed" >&2
  echo "  source sourceme" >&2
  exit 1
fi

_picblobs_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v task >/dev/null 2>&1; then
  echo "error: 'task' not found. Install it: https://taskfile.dev/installation/" >&2
  return 1
fi

( cd "${_picblobs_root}" && task setup ) || return 1

echo "==> Ready. Tools are provided by Task/Bazel targets. Try: task --list"

unset _picblobs_root
