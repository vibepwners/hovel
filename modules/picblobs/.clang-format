BasedOnStyle: LLVM
UseTab: Always
IndentWidth: 8
TabWidth: 8
ContinuationIndentWidth: 8

BreakBeforeBraces: Linux
BraceWrapping:
  AfterFunction: true
  AfterControlStatement: false

AlignAfterOpenBracket: false
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignOperands: DontAlign

# Barr-C 1.3.a: braces shall always surround the bodies of if/else/for/while/
# switch/do, including single and empty statements. clang-format inserts the
# braces on `task fmt` and `task fmt:check` fails if any are missing.
# (Brace placement stays K&R per AfterControlStatement: false above.)
InsertBraces: true

ColumnLimit: 80
