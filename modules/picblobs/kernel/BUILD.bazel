load("@rules_shell//shell:sh_test.bzl", "sh_test")

# Kernel module VM tests — hermetic QEMU-based testing
#
# Usage:
#   bazel test //modules/picblobs/kernel:ubuntu_suite
#   bazel test //modules/picblobs/kernel:kshell_ubuntu

_DATA = glob([
    "**/*.py",
    "**/*.c",
    "**/*.h",
    "**/*.S",
    "**/Makefile",
])

filegroup(
    name = "quality_sources",
    srcs = glob(
        [
            "**/*.S",
            "**/*.c",
            "**/*.h",
            "**/*.py",
            "**/Makefile",
        ],
        allow_empty = True,
    ) + ["BUILD.bazel"],
    visibility = ["//visibility:public"],
)

_TAGS = [
    "manual",
    "exclusive",
    "no-sandbox",
]

# --- Ubuntu 24.04 ---

sh_test(
    name = "kmod_build_ubuntu",
    size = "enormous",
    timeout = "eternal",
    srcs = ["run_vm_test.sh"],
    args = [
        "kmod-build",
        "ubuntu",
        "600",
    ],
    data = _DATA,
    tags = _TAGS,
)

