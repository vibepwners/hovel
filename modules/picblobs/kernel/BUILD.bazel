# --- Suites ---

test_suite(
    name = "ubuntu_suite",
    tags = ["manual"],
    tests = [
        ":examples_build_ubuntu",
        ":kmod_build_ubuntu",
        ":kmod_nopanic_ubuntu",
        ":kshell_ff_ubuntu",
        ":kshell_nacl_ubuntu",
        ":kshell_ubuntu",
        ":kshell_upload_ubuntu",
    ],
)

test_suite(
    name = "alpine_suite",
    tags = ["manual"],
    tests = [
        ":kmod_build_alpine",
    ],
)
