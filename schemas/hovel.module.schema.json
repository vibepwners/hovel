{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hovel.dev/schemas/hovel.module.schema.json",
  "title": "Hovel Module Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "const": "hovel.dev/v1alpha1"
    },
    "kind": {
      "const": "Module"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["runtime", "moduleType"],
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "entrypoint"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["jsonrpc-stdio"]
            },
            "packaging": {
              "type": "string"
            },
            "entrypoint": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "moduleType": {
          "type": "string",
          "enum": ["survey", "exploit", "payload_provider"]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inputs": {
          "type": "object"
        },
        "outputs": {
          "type": "object"
        },
        "requires": {
          "type": "object"
        },
        "risk": {
          "type": "object"
        }
      }
    }
  }
}
