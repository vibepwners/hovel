load("@gazelle//:def.bzl", "gazelle")

package(default_visibility = ["//visibility:public"])

gazelle(
    name = "gazelle",
    prefix = "github.com/Vibe-Pwners/hovel",
)

filegroup(
    name = "license",
    srcs = ["LICENSE"],
)

filegroup(
    name = "docs_sources",
    srcs = [
        "spec.md",
        "//spec:sources",
    ],
)

filegroup(
    name = "docs",
    srcs = ["//spec:book"],
)

filegroup(
    name = "build",
    srcs = [
        ":docs",
        "//cmd/hovel",
        "//cmd/hoveld",
        "//schemas:descriptor_schemas",
    ],
)

test_suite(
    name = "test",
    tests = [
        "//internal/adapters/cli:cli_test",
        "//internal/adapters/storage/filesystem:filesystem_test",
        "//internal/app/apptest:apptest_test",
        "//internal/app/services:services_test",
        "//internal/domain/daemon:daemon_test",
        "//internal/domain/event:event_test",
        "//internal/domain/workspace:workspace_test",
        "//schemas:schema_smoke_test",
        "//spec:book_smoke_test",
    ],
)
