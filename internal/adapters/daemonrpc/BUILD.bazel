load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "daemonrpc",
    srcs = ["daemonrpc.go"],
    importpath = "github.com/Vibe-Pwners/hovel/internal/adapters/daemonrpc",
    visibility = ["//visibility:public"],
    deps = [
        "//internal/app/operatorlog",
        "//internal/app/operatorsession",
        "//internal/app/services",
        "//internal/domain/run",
