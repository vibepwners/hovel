go_test(
    name = "daemonrpc_test",
    size = "small",
    srcs = ["daemonrpc_test.go"],
    embed = [":daemonrpc"],
    deps = [
        "//internal/app/operatorsession",
        "//internal/app/services",
        "//internal/domain/event",
        "//internal/modules/mockexploit",
    ],
)
