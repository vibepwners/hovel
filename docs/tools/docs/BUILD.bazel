load("@rules_python//python:defs.bzl", "py_binary")

package(default_visibility = ["//visibility:public"])

exports_files(["daemon_rpc_openapi_test.py"])

py_binary(
    name = "stage_site",
    srcs = [
        "check_site_links.py",
        "generate_sdk_api_docs.py",
        "site_chrome.py",
        "stage_site.py",
    ],
    args = [
        "--uv-bin=$(rootpath @uv_linux_x86_64//:uv_bin)",
        "--go-bin=$(rootpath @go_sdk//:bin/go)",
        # rules_rust exposes generated tool repositories only by canonical
        # extension names; rootpath and data must use the matching label.
        "--rustdoc-bin=$(rootpath @@rules_rust++rust+rust_linux_x86_64__x86_64-unknown-linux-gnu__stable_tools//:rustdoc)",  # buildifier: disable=canonical-repository
    ],
    data = [
        "//docs/demo:all_gif_manifest",
        "@@rules_rust++rust+rust_linux_x86_64__x86_64-unknown-linux-gnu__stable_tools//:rustc_lib",  # buildifier: disable=canonical-repository
        "@@rules_rust++rust+rust_linux_x86_64__x86_64-unknown-linux-gnu__stable_tools//:rustdoc",  # buildifier: disable=canonical-repository
        "@go_sdk//:bin/go",
        "@uv_linux_x86_64//:uv_bin",
    ],
    main = "stage_site.py",
    python_version = "PY3",
)
