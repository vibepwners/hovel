load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

licenses(["restricted"])

cc_library(
    name = "wolfssl",
    srcs = [
        "src/internal.c",
        "src/keys.c",
        "src/ssl.c",
        "src/tls.c",
        "src/tls13.c",
        "src/wolfio.c",
        "wolfcrypt/src/aes.c",
        "wolfcrypt/src/asn.c",
        "wolfcrypt/src/coding.c",
        "wolfcrypt/src/cpuid.c",
        "wolfcrypt/src/ecc.c",
        "wolfcrypt/src/hash.c",
        "wolfcrypt/src/hmac.c",
        "wolfcrypt/src/kdf.c",
        "wolfcrypt/src/logging.c",
        "wolfcrypt/src/memory.c",
        "wolfcrypt/src/misc.c",
        "wolfcrypt/src/random.c",
        "wolfcrypt/src/rsa.c",
        "wolfcrypt/src/sha256.c",
        "wolfcrypt/src/signature.c",
        "wolfcrypt/src/tfm.c",
        "wolfcrypt/src/wc_port.c",
        "wolfcrypt/src/wolfmath.c",
    ],
    hdrs = glob([
        "wolfssl/**/*.h",
    ]),
    textual_hdrs = [
        "src/bio.c",
        "src/conf.c",
        "src/pk.c",
        "src/pk_ec.c",
        "src/pk_rsa.c",
        "src/ssl_api_cert.c",
        "src/ssl_api_crl_ocsp.c",
        "src/ssl_api_dtls.c",
        "src/ssl_api_ext.c",
        "src/ssl_api_pk.c",
        "src/ssl_asn1.c",
        "src/ssl_bn.c",
        "src/ssl_certman.c",
        "src/ssl_crypto.c",
        "src/ssl_ech.c",
        "src/ssl_load.c",
        "src/ssl_misc.c",
        "src/ssl_p7p12.c",
        "src/ssl_sess.c",
        "src/ssl_sk.c",
        "src/x509.c",
        "src/x509_str.c",
        "wolfcrypt/src/asm.c",
        "wolfcrypt/src/asn_orig.c",
        "wolfcrypt/src/evp.c",
        "wolfcrypt/src/evp_pk.c",
    ],
    copts = [
        "-DDECLSPEC_IMPORT=",
        "-DUNICODE",
        "-D_UNICODE",
        "-DWINVER=0x0400",
        "-D_WIN32_WINNT=0x0400",
        "-DBUILDING_WOLFSSL",
        "-DWOLFSSL_USER_SETTINGS",
        "-fno-asynchronous-unwind-tables",
        "-fno-builtin",
        "-fno-stack-protector",
        "-fno-unwind-tables",
        "-Wno-deprecated-declarations",
        "-Wno-missing-braces",
        "-Wno-sign-compare",
        "-Wno-unused-function",
        "-Wno-unused-parameter",
        "-Wno-unused-variable",
    ],
    defines = ["WOLFSSL_USER_SETTINGS"],
    includes = ["."],
    linkopts = ["-lgcc"],
    target_compatible_with = ["@platforms//os:windows"],
    deps = ["@//third_party/wolfssl:squatter_config"],
)

filegroup(
    name = "license",
    srcs = [
        "COPYING",
        "LICENSING",
    ],
)
