common --announce_rc

build --color=yes
build --curses=yes
build --action_env=PYTHONDONTWRITEBYTECODE=1

test --test_output=errors
test --test_env=PYTHONDONTWRITEBYTECODE=1

build:buildbuddy --bes_backend=grpcs://remote.buildbuddy.io
build:buildbuddy --bes_results_url=https://app.buildbuddy.io/invocation/
build:buildbuddy --remote_cache=grpcs://remote.buildbuddy.io
build:buildbuddy --remote_cache_compression=true
build:buildbuddy --remote_upload_local_results=false

build:local-cache --disk_cache=/var/tmp/bazel-cache/hovel
build:local-cache --remote_upload_local_results=true

# NativeLink remote execution uses the remote CAS as the cache. Do NOT add
# --disk_cache (i.e. --config=local-cache) here: combined with --remote_executor,
# Bazel satisfies input blobs from the local disk cache without uploading them to
# the remote CAS, so the worker fails with "Object not found in either fast or
# slow store" (e.g. the hermetic Python interpreter). Remote cache only.
build:nativelink --remote_cache=grpc://nativelink:50051
build:nativelink --remote_executor=grpc://nativelink:50051
build:nativelink --remote_upload_local_results=true

build:nativelink-minimal --config=nativelink
build:nativelink-minimal --remote_download_minimal

build:local --config=local-cache

build:ci --config=buildbuddy
build:ci --build_metadata=ROLE=CI
build:ci --noslim_profile
build:ci --experimental_profile_include_target_label
build:ci --experimental_profile_include_primary_output
build:ci --remote_upload_local_results=true

try-import %workspace%/.bazelrc.user
