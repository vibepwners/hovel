{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hovel.dev/schemas/hovel.module.schema.json",
  "title": "Hovel Module Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "const": "hovel.dev/v1alpha1"
    },
    "kind": {
      "const": "Module"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["runtime", "moduleType"],
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "entrypoint"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["jsonrpc-stdio"]
            },
            "packaging": {
              "type": "string"
            },
            "entrypoint": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "moduleType": {
          "type": "string",
          "enum": ["survey", "exploit", "payload_provider"]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inputs": {
          "type": "object"
        },
        "outputs": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "artifacts": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/artifactOutput"
              }
            },
            "payloads": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/payloadOutput"
              }
            }
          }
        },
        "requires": {
          "type": "object"
        },
        "risk": {
          "type": "object"
        }
      }
    }
  },
  "$defs": {
    "artifactOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "mode"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["inline", "file"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "payloadOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "formats"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/payloadKind"
        },
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/payloadFormat"
          }
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "payloadKind": {
      "type": "string",
      "enum": ["pic", "poc", "elf", "pe", "so", "dll", "dylib", "raw"]
    },
    "payloadFormat": {
      "type": "string",
      "enum": ["pic", "poc", "flat-pic", "raw-bin", "elf", "elf-exec", "so", "pe", "pe-exe", "pe-dll", "dll", "dylib", "macho-dylib"]
    }
  }
}
