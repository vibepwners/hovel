load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "rootcli",
    srcs = [
        "logging.go",
        "rootcli.go",
    ],
    importpath = "github.com/Vibe-Pwners/hovel/internal/adapters/rootcli",
    visibility = ["//visibility:public"],
    deps = [
        "//internal/adapters/cli",
        "//internal/adapters/commandmode",
        "//internal/adapters/daemonrpc",
        "//internal/adapters/mcp",
        "//internal/app/modulecatalog",
        "//internal/app/services",
        "//internal/domain/daemon",
        "//internal/domain/workspace",
        "//internal/infra/daemonmanager",
        "//internal/infra/daemonruntime",
        "//internal/moduleruntime/pythonrpc",
        "@com_github_akamensky_argparse//:argparse",
    ],
)

# keep: fast root command/help checks stay separate from daemon E2E coverage.
go_test(
    name = "rootcli_test",
    size = "small",
    srcs = [
        "rootcli_test.go",
        "rootcli_test_helpers_test.go",
    ],
    data = [
    ],
    embed = [":rootcli"],
    tags = [
        "manual",
        "unit",
    ],
    deps = [
        "//internal/testsupport",
    ],
)

# keep: mono-binary daemon flows are process-level E2E checks.
go_test(
    name = "rootcli_e2e_test",
    size = "small",
    srcs = [
        "rootcli_e2e_test.go",
        "rootcli_test_helpers_test.go",
    ],
    data = [
    ],
    embed = [":rootcli"],
    tags = [
        "e2e",
        "manual",
    ],
    deps = [
        "//internal/adapters/storage/filesystem",
        "//internal/domain/daemon",
        "//internal/testsupport",
    ],
)
