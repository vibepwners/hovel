load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "daemonrpc",
    srcs = [
        "daemonrpc.go",
        "mesh_book.go",
        "mesh_bridge.go",
    ],
    importpath = "github.com/vibepwners/hovel/internal/adapters/daemonrpc",
    visibility = ["//:__subpackages__"],
    deps = [
        "//internal/app/launchkey",
        "//internal/app/operatorlog",
        "//internal/app/operatorsession",
        "//internal/app/pki",
        "//internal/app/services",
        "//internal/domain/mesh",
        "//internal/domain/operator",
        "//internal/domain/pki",
        "//internal/domain/run",
    ],
)

go_test(
    name = "daemonrpc_test",
    size = "small",
    srcs = ["daemonrpc_test.go"],
    embed = [":daemonrpc"],
    deps = [
        "//internal/app/operatorlog",
        "//internal/app/operatorsession",
        "//internal/app/pki",
        "//internal/app/services",
        "//internal/domain/event",
        "//internal/domain/mesh",
        "//internal/domain/operator",
        "//internal/domain/pki",
        "//internal/domain/run",
        "//internal/testmodules/mockexploit",
    ],
)

go_test(
    name = "daemonrpc_race_test",
    size = "small",
    srcs = ["daemonrpc_test.go"],
    embed = [":daemonrpc"],
    race = "on",
    tags = ["manual"],
    deps = [
        "//internal/app/operatorlog",
        "//internal/app/operatorsession",
        "//internal/app/services",
        "//internal/domain/event",
        "//internal/domain/mesh",
        "//internal/domain/operator",
        "//internal/domain/run",
        "//internal/testmodules/mockexploit",
    ],
)

filegroup(
    name = "daemonrpc_source",
    srcs = ["daemonrpc.go"],
    visibility = ["//docs/site/spec:__pkg__"],
)
